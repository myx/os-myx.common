#!/bin/sh

## NOTE: because of ubuntu not supporting the '-l' option

export SedLineReader='stdbuf -oL -eL sed -u'
alias SedLineReader='stdbuf -oL -eL sed -u'

# SedLineReader(){
# 	stdbuf -oL -eL sed -u "$@"
# }

case "$0" in
	*/myx.common/bin/lib/sedLineReader.*) 
		if [ -z "$1" ] || [ "$1" = "--help" ] ; then
			. "${MYXROOT:-/usr/local/share/myx.common}/help/lib/sedLineReader.help.include" >&2
			exit 1
		fi
		set -e
		$SedLineReader "$@"
	;;
esac
