#!/bin/sh

## NOTE: because of macosx not supporting the '-u' option

export SedInteractive='sed'
alias SedInteractive='sed'

# SedInteractive(){
# 	sed "$@"
# }

case "$0" in
	*/myx.common/bin/lib/sedInteractive.*) 
		if [ -z "$1" ] || [ "$1" = "--help" ] ; then
			. "${MYXROOT:-/usr/local/share/myx.common}/help/lib/sedInteractive.help.include" >&2
			exit 1
		fi
		set -e
		$SedInteractive "$@"
	;;
esac
