#!/bin/sh

# This script is universal for FreeBSD, Darwin, Ubuntu.

Which(){
	local MYXROOT="${MYXROOT:-/usr/local/share/myx.common}" UNAME=$MYXUNIX

	while [ $# -gt 0 ]; do case "$1" in
		--uname) UNAME=$2 ; shift 2 ;;
		*) break ;;
	esac done

	[ -n "$1" ] || { echo "⛔ ERROR: Which: COMMAND argument is required!" >&2; exit 1; }
	[ -n "$UNAME" ] || UNAME=$(uname -s)
	local COMMAND="$( ls -1fd "$MYXROOT/bin/$1.$UNAME" "$MYXROOT/bin/$1.Common" "$MYXROOT/include/obsolete/user/bin/$1" 2>/dev/null | head -n1 || : )"
	if [ -f "$COMMAND" ]; then
		echo "$COMMAND"
		return 0
	fi
	return 1
}

case "$0" in
	*/myx.common/bin/which.Common) 
		if [ -z "$1" ] || [ "$1" = "--help" ] ; then
			. "${MYXROOT:-/usr/local/share/myx.common}/help/which.help.include" >&2
			exit 1
		fi
		set -e
		Which "$@"
	;;
esac
