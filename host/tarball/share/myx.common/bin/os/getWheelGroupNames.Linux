#!/bin/sh

##### !!! THIS SCRIPT MUST BE OVERRIDEN IN OS-DEPENDENT IMPLEMENTATION !!! #####

OsGetWheelGroupNames(){
	echo "adm sudo"
}


case "$0" in
	*/myx.common/bin/os/getWheelGroupNames.*) 
		if [ "$1" = "--help" ] ; then
			. "${MYXROOT:-/usr/local/share/myx.common}/help/os/getWheelGroupNames.help.include" >&2
			exit 1
		fi
		# set -e
		# OsGetWheelGroupNames "$@"
		echo "adm"
	;;
esac
