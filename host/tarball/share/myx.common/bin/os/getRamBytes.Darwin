#!/bin/sh

##### !!! THIS SCRIPT MUST BE OVERRIDEN IN OS-DEPENDENT IMPLEMENTATION !!! #####

OsGetRamBytes(){
	sysctl -n hw.memsize
}


case "$0" in
	*/myx.common/bin/os/getRamBytes.*) 
		if [ "$1" = "--help" ] ; then
			. "${MYXROOT:-/usr/local/share/myx.common}/help/os/getRamBytes.help.include" >&2
			exit 1
		fi
		set -e
		OsGetRamBytes "$@"
	;;
esac
