#!/bin/sh

##### !!! THIS SCRIPT MUST BE OVERRIDEN IN OS-DEPENDENT IMPLEMENTATION !!! #####

OsGetRamBytes(){
	echo "⛔ ERROR: OsGetRamBytes must be re-implemented" >&2
	exit 1
}


case "$0" in
	*/myx.common/bin/os/getRamBytes.Common) 
		if [ "$1" = "--help" ] ; then
			. "${MYXROOT:-/usr/local/share/myx.common}/help/os/getRamBytes.help.include" >&2
			exit 1
		fi
		set -e
		OsGetRamBytes "$@"
	;;
esac
