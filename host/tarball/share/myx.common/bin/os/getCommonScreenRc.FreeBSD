#!/bin/sh

##### !!! THIS SCRIPT MUST BE OVERRIDEN IN OS-DEPENDENT IMPLEMENTATION !!! #####

OsGetCommonScreenRc(){
	echo /usr/local/etc/screenrc
}


case "$0" in
	*/myx.common/bin/os/getCommonScreenRc.*) 
		if [ "$1" = "--help" ] ; then
			. "${MYXROOT:-/usr/local/share/myx.common}/help/os/getCommonScreenRc.help.include" >&2
			exit 1
		fi
		# set -e
		# OsGetCommonScreenRc "$@"
		echo /usr/local/etc/screenrc
	;;
esac
