#!/bin/sh

##### !!! THIS SCRIPT MUST BE OVERRIDEN IN OS-DEPENDENT IMPLEMENTATION !!! #####

OsGrowSlashFsLinuxTrim(){
	echo "$*" | awk '{$1=$1; print}'
}

OsGrowSlashFsLinuxHasCommand(){
	command -v "$1" >/dev/null 2>&1
}

OsGrowSlashFsLinuxRequireCommand(){
	local CMD_NAME="$1"
	OsGrowSlashFsLinuxHasCommand "$CMD_NAME" || {
		echo "⛔ ERROR: required command is missing: ${CMD_NAME}" >&2
		return 1
	}
}

OsGrowSlashFsLinuxGetRootSource(){
	if OsGrowSlashFsLinuxHasCommand findmnt; then
		findmnt -n -o SOURCE /
		return 0
	fi

	[ -r /proc/mounts ] || return 1
	awk '$2=="/" {print $1; exit}' /proc/mounts
}

OsGrowSlashFsLinuxGetFsType(){
	if OsGrowSlashFsLinuxHasCommand findmnt; then
		findmnt -n -o FSTYPE /
		return 0
	fi

	[ -r /proc/mounts ] || return 1
	awk '$2=="/" {print $3; exit}' /proc/mounts
}

OsGrowSlashFsLinuxResolveLvPath(){
	local SRC="$1"
	local LV=""

	if OsGrowSlashFsLinuxHasCommand lvs; then
		LV="$(lvs --noheadings -o lv_path "$SRC" 2>/dev/null | OsGrowSlashFsLinuxTrim || true)"
		if [ "$LV" != "" ]; then
			echo "$LV"
			return 0
		fi
	fi

	readlink -f "$SRC" 2>/dev/null || echo "$SRC"
}

OsGrowSlashFsLinuxResolveVgName(){
	local SRC="$1"
	local VG=""

	if OsGrowSlashFsLinuxHasCommand lvs; then
		VG="$(lvs --noheadings -o vg_name "$SRC" 2>/dev/null | OsGrowSlashFsLinuxTrim || true)"
		if [ "$VG" != "" ]; then
			echo "$VG"
			return 0
		fi
	fi

	echo ""
}

OsGrowSlashFsLinuxResolveFirstPvForVg(){
	local VG="$1"
	local PV=""

	if [ "$VG" = "" ]; then
		echo ""
		return 0
	fi

	if OsGrowSlashFsLinuxHasCommand pvs; then
		PV="$(pvs --noheadings -o pv_name,vg_name 2>/dev/null | awk -v vg="$VG" '$2==vg {print $1; exit}')"
		PV="$(OsGrowSlashFsLinuxTrim "$PV")"
		if [ "$PV" != "" ]; then
			echo "$PV"
			return 0
		fi
	fi

	if OsGrowSlashFsLinuxHasCommand pvdisplay; then
		PV="$(pvdisplay -C --noheading -o pv_name,vg_name 2>/dev/null | awk -v vg="$VG" '$2==vg {print $1; exit}')"
		PV="$(OsGrowSlashFsLinuxTrim "$PV")"
		if [ "$PV" != "" ]; then
			echo "$PV"
			return 0
		fi
	fi

	echo ""
}

OsGrowSlashFsLinuxResolveDiskAndPartNum(){
	local DEV="$1"
	local PKNAME=""
	local PARTN=""

	if ! OsGrowSlashFsLinuxHasCommand lsblk; then
		echo "|"
		return 0
	fi

	PKNAME="$(lsblk -no PKNAME "$DEV" 2>/dev/null | head -n1 | OsGrowSlashFsLinuxTrim || true)"
	PARTN="$(lsblk -no PARTN "$DEV" 2>/dev/null | head -n1 | OsGrowSlashFsLinuxTrim || true)"

	if [ "$PKNAME" != "" ] && [ "$PARTN" != "" ]; then
		echo "/dev/${PKNAME}|${PARTN}"
		return 0
	fi

	echo "|"
}

OsGrowSlashFsLinuxAppendCommand(){
	local COMMANDS_VALUE="$1"
	local COMMAND_VALUE="$2"

	if [ "$COMMANDS_VALUE" = "" ]; then
		echo "$COMMAND_VALUE"
	else
		echo "$COMMANDS_VALUE && $COMMAND_VALUE"
	fi
}

OsGrowSlashFsLinux(){
	local EXECUTE="$1"
	local SUDO_PREFIX=""
	local ROOT_SRC=""
	local FS_TYPE=""
	local LV_PATH=""
	local VG_NAME=""
	local PV_DEV=""
	local DISK_DEV=""
	local PART_NUM=""
	local DISK_AND_PART=""
	local TYPE_HINT=""
	local IS_LVM=false
	local COMMANDS=""
	local CMD=""

	set -e

	if [ "$(id -u)" -ne 0 ] && OsGrowSlashFsLinuxHasCommand sudo; then
		SUDO_PREFIX="sudo "
	fi

	ROOT_SRC="$(OsGrowSlashFsLinuxGetRootSource 2>/dev/null || true)"
	FS_TYPE="$(OsGrowSlashFsLinuxGetFsType 2>/dev/null || true)"

	if [ "$ROOT_SRC" = "" ]; then
		echo "⛔ ERROR: cannot determine root source" >&2
		return 1
	fi

	case "$ROOT_SRC" in
		/dev/mapper/*)
			IS_LVM=true
		;;
		*)
			if OsGrowSlashFsLinuxHasCommand lsblk; then
				TYPE_HINT="$(lsblk -no TYPE "$ROOT_SRC" 2>/dev/null | head -n1 | OsGrowSlashFsLinuxTrim || true)"
				if [ "$TYPE_HINT" = "lvm" ]; then
					IS_LVM=true
				fi
			fi
		;;
	esac

	if [ "$IS_LVM" = "true" ]; then
		LV_PATH="$(OsGrowSlashFsLinuxResolveLvPath "$ROOT_SRC")"
		VG_NAME="$(OsGrowSlashFsLinuxResolveVgName "$ROOT_SRC")"
		PV_DEV="$(OsGrowSlashFsLinuxResolveFirstPvForVg "$VG_NAME")"
		if [ "$PV_DEV" != "" ]; then
			DISK_AND_PART="$(OsGrowSlashFsLinuxResolveDiskAndPartNum "$PV_DEV")"
			DISK_DEV="$(echo "$DISK_AND_PART" | cut -d'|' -f1)"
			PART_NUM="$(echo "$DISK_AND_PART" | cut -d'|' -f2)"
		fi
	else
		LV_PATH="$ROOT_SRC"
		PV_DEV="$ROOT_SRC"
		DISK_AND_PART="$(OsGrowSlashFsLinuxResolveDiskAndPartNum "$ROOT_SRC")"
		DISK_DEV="$(echo "$DISK_AND_PART" | cut -d'|' -f1)"
		PART_NUM="$(echo "$DISK_AND_PART" | cut -d'|' -f2)"
	fi

	if [ "$DISK_DEV" != "" ] && [ "$PART_NUM" != "" ]; then
		COMMANDS="$(OsGrowSlashFsLinuxAppendCommand "$COMMANDS" "${SUDO_PREFIX}growpart ${DISK_DEV} ${PART_NUM}")"
	fi

	if [ "$IS_LVM" = "true" ]; then
		if [ "$PV_DEV" != "" ]; then
			COMMANDS="$(OsGrowSlashFsLinuxAppendCommand "$COMMANDS" "${SUDO_PREFIX}pvresize ${PV_DEV}")"
		fi

		COMMANDS="$(OsGrowSlashFsLinuxAppendCommand "$COMMANDS" "${SUDO_PREFIX}lvextend -l +100%FREE ${LV_PATH}")"

		case "$FS_TYPE" in
			xfs)
				COMMANDS="$(OsGrowSlashFsLinuxAppendCommand "$COMMANDS" "${SUDO_PREFIX}xfs_growfs /")"
			;;
			ext2|ext3|ext4)
				COMMANDS="$(OsGrowSlashFsLinuxAppendCommand "$COMMANDS" "${SUDO_PREFIX}resize2fs ${LV_PATH}")"
			;;
			btrfs)
				COMMANDS="$(OsGrowSlashFsLinuxAppendCommand "$COMMANDS" "${SUDO_PREFIX}btrfs filesystem resize max /")"
			;;
			*)
				echo "⛔ ERROR: unsupported filesystem for auto-grow: ${FS_TYPE:-<unknown>}" >&2
				return 1
			;;
		esac
	else
		case "$FS_TYPE" in
			xfs)
				COMMANDS="$(OsGrowSlashFsLinuxAppendCommand "$COMMANDS" "${SUDO_PREFIX}xfs_growfs /")"
			;;
			ext2|ext3|ext4)
				COMMANDS="$(OsGrowSlashFsLinuxAppendCommand "$COMMANDS" "${SUDO_PREFIX}resize2fs ${PV_DEV}")"
			;;
			btrfs)
				COMMANDS="$(OsGrowSlashFsLinuxAppendCommand "$COMMANDS" "${SUDO_PREFIX}btrfs filesystem resize max /")"
			;;
			*)
				echo "⛔ ERROR: unsupported filesystem for auto-grow: ${FS_TYPE:-<unknown>}" >&2
				return 1
			;;
		esac
	fi

	if [ "$COMMANDS" = "" ]; then
		echo "⛔ ERROR: nothing to do; no actionable plan was built" >&2
		return 1
	fi

	echo "Detected values" >&2
	echo "ROOT_SRC: ${ROOT_SRC}" >&2
	echo "IS_LVM: ${IS_LVM}" >&2
	echo "LV_PATH: ${LV_PATH:-<none>}" >&2
	echo "VG_NAME: ${VG_NAME:-<none>}" >&2
	echo "PV_DEV: ${PV_DEV:-<none>}" >&2
	echo "DISK_DEV: ${DISK_DEV:-<none>}" >&2
	echo "PART_NUM: ${PART_NUM:-<none>}" >&2
	echo "FS_TYPE: ${FS_TYPE:-<unknown>}" >&2
	echo "" >&2
	echo "Planned command" >&2
	echo "$COMMANDS" >&2

	if [ "$EXECUTE" != "--execute" ]; then
		echo "" >&2
		echo "Preview only. Re-run with --execute to apply." >&2
		return 0
	fi

	for CMD in growpart pvresize lvextend xfs_growfs resize2fs btrfs ; do
		case " $COMMANDS " in
			*" ${SUDO_PREFIX}${CMD} "*)
				OsGrowSlashFsLinuxRequireCommand "$CMD"
			;;
		esac
	done

	if [ "$SUDO_PREFIX" != "" ]; then
		OsGrowSlashFsLinuxRequireCommand sudo
	fi

	echo "" >&2
	echo "Executing plan" >&2
	set -x
	sh -c "$COMMANDS"
	set +x

	echo "Done" >&2
	return 0
}

case "$0" in
	*/myx.common/bin/os/growSlashFs.*)
		if [ "$1" = "--help" ] ; then
			echo "Syntax: myx.common os/growSlashFs --execute" >&2
			echo "    or: myx.common os/growSlashFs" >&2
			exit 1
		fi
		set -e
		if [ "$1" = "--execute" ] ; then
			OsGrowSlashFsLinux --execute
			exit $?
		fi
		OsGrowSlashFsLinux
	;;
esac
