echo '📘 Syntax: myx.common lib/linesToArguments [--act '"'"'command'"'"'] ['"'"'sed'"'"' arguments, see '"'"'man sed'"'"'...]' >&2
echo '📘 Syntax: myx.common lib/linesToArguments --help' >&2
echo '' >&2
[ "$1" != '--help' ] || myx.common lib/catMarkdown "${MYXROOT:=/usr/local/share/myx.common}/help/lib/linesToArguments.help.md" >&2
