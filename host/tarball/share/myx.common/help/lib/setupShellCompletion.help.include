echo '📘 Syntax: myx.common lib/setupShellCompletion <utility-name> --command <list-command>' >&2
echo '📘 Syntax: myx.common lib/setupShellCompletion <utility-name> --directory <list-directory>' >&2
echo '📘 Syntax: myx.common lib/setupShellCompletion <utility-name> --remove' >&2
echo '📘 Syntax: myx.common lib/setupShellCompletion --help' >&2
echo '' >&2
[ "$1" != '--help' ] || myx.common lib/catMarkdown "${MYXROOT:=/usr/local/share/myx.common}/help/lib/setupShellCompletion.help.md" >&2
