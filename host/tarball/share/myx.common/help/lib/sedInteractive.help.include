echo '📘 Syntax: myx.common lib/sedInteractive ['"'"'sed'"'"' arguments, see '"'"'man sed'"'"'...]' >&2
echo '📘 Syntax: myx.common lib/sedInteractive --help' >&2
echo '' >&2
[ "$1" != '--help' ] || myx.common lib/catMarkdown "${MYXROOT:=/usr/local/share/myx.common}/help/lib/sedInteractive.help.md" >&2
