echo '📘 Syntax: myx.common lib/remoteContext [<option> ...] <context-spec> [<context-spec> ...]' >&2
echo '📘 Syntax: myx.common lib/remoteContext [--interactive] [--force] [--verbose] --insert-{tarball|path|script|command} <path-or-value> [<path-or-value> ...]' >&2
echo '📘 Syntax: myx.common lib/remoteContext [<option> ...] [--insert-path <path>|--insert-path <base-path>:<relative-path>] [--insert-script <script-source-path>] [--insert-command <script-source>] [--do-ssh <host>]' >&2
echo '📘 Syntax: myx.common lib/remoteContext --help' >&2
[ "$1" != '--help' ] || cat "${MYXROOT:=/usr/local/share/myx.common}/help/lib/remoteContext.help.md" >&2
