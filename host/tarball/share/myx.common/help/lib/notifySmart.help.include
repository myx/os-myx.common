echo '📘 Syntax: myx.common lib/notifySmart --alert|--audit|--track|--debug [--user <user-name>] [--emoji <emoji>] --text <message>' >&2
echo '📘 Syntax: myx.common lib/notifySmart --help' >&2
echo '' >&2
[ "$1" != '--help' ] || myx.common lib/catMarkdown "${MYXROOT:=/usr/local/share/myx.common}/help/lib/notifySmart.help.md" >&2
