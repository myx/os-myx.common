echo '📘 Syntax: myx.common lib/installAuthorizedKey <user-name> <ssh-key> [--remove]' >&2
echo '📘 Syntax: myx.common lib/installAuthorizedKey --help' >&2
echo '' >&2
[ "$1" != '--help' ] || myx.common lib/catMarkdown "${MYXROOT:=/usr/local/share/myx.common}/help/lib/installAuthorizedKey.help.md" >&2
