echo '📘 Syntax: myx.common lib/out status <red|green|yellow> <message>' >&2
echo '📘 Syntax: myx.common lib/out error|info|example <message>' >&2
echo '📘 Syntax: myx.common lib/out syntax <message>' >&2
echo '📘 Syntax: myx.common lib/out valuechange <setting> <target> <new-value> [<old-value>]' >&2
echo '📘 Syntax: myx.common lib/out message <text> [waitstatus] [<short-text>]' >&2
echo '📘 Syntax: myx.common lib/out nextrelease' >&2
echo '📘 Syntax: myx.common lib/out --help' >&2
echo '' >&2
[ "$1" != '--help' ] || myx.common lib/catMarkdown "${MYXROOT:=/usr/local/share/myx.common}/help/lib/out.help.md" >&2
