echo '📘 Syntax: myx.common lib/installUserPasswordHash <username> <password-hash>' >&2
echo '📘 Syntax: myx.common lib/installUserPasswordHash --help' >&2
echo '' >&2
[ "$1" != '--help' ] || myx.common lib/catMarkdown "${MYXROOT:=/usr/local/share/myx.common}/help/lib/installUserPasswordHash.help.md" >&2
